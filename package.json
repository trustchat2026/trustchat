{
  "name": "trustchat-desktop",
  "version": "1.2.0",
  "description": "Universal TrustChat Desktop app with automated GitHub Actions build for Windows and macOS.",
  "main": "src/main.js",
  "author": "TrustWeb",
  "license": "UNLICENSED",
  "private": true,
  "productName": "TrustChat Desktop",
  "scripts": {
    "start": "electron .",
    "verify": "node scripts/verify.js",
    "dist:win": "npm run verify && electron-builder --win nsis",
    "dist:mac": "npm run verify && electron-builder --mac dmg",
    "dist:linux": "npm run verify && electron-builder --linux AppImage"
  },
  "build": {
    "appId": "vn.trustweb.trustchat.desktop",
    "productName": "TrustChat Desktop",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets/icon.png",
        "to": "icon.png"
      }
    ],
    "protocols": [
      {
        "name": "TrustChat Desktop",
        "schemes": [
          "trustchat"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icons/icon.ico",
      "artifactName": "TrustChat-Desktop-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TrustChat Desktop",
      "deleteAppDataOnUninstall": false
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.business",
      "icon": "build/icons/icon.icns",
      "artifactName": "TrustChat-Desktop-${version}.${ext}"
    },
    "dmg": {
      "title": "TrustChat Desktop"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icons/icon.png",
      "category": "Office",
      "artifactName": "TrustChat-Desktop-${version}.${ext}"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
